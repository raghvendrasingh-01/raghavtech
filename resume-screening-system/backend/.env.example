# Copy to .env and fill in. The .env file is gitignored.
# In production (Render), set these in the dashboard instead of a file.

# OpenRouter API key — get one at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...

# Model id for AI suggestions (any model on https://openrouter.ai/models).
# Examples: openai/gpt-4o-mini, meta-llama/llama-3.3-70b-instruct,
#           google/gemini-flash-1.5, anthropic/claude-3.5-sonnet
OPENROUTER_MODEL=openai/gpt-4o-mini

# --- CORS ---
# Comma-separated browser origins allowed to call this API. MUST include your
# deployed frontend origin in production, or the browser blocks responses.
# Local dev default (when unset): http://localhost:5173,http://127.0.0.1:5173
# Production example:
CORS_ORIGINS=https://your-portfolio.vercel.app

# Optional regex for additional origins (e.g. Vercel preview deployments).
# Leave blank to disable. Example:
# CORS_ORIGIN_REGEX=https://.*\.vercel\.app
CORS_ORIGIN_REGEX=
