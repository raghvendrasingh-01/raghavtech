# Copy to .env and fill in. The .env file is gitignored.

# OpenRouter API key — get one at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...

# Model id for AI suggestions (any model on https://openrouter.ai/models).
# Examples: openai/gpt-4o-mini, meta-llama/llama-3.3-70b-instruct,
#           google/gemini-flash-1.5, anthropic/claude-3.5-sonnet
OPENROUTER_MODEL=openai/gpt-4o-mini
