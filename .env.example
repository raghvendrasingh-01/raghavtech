# Portfolio frontend (Vite) environment variables.
# Copy to `.env.local` for local dev and set the same keys in the Vercel
# project settings for production. Only VITE_-prefixed vars are exposed to the
# browser bundle. The actual `.env*` files are gitignored.

# --- AI Resume Screening backend ---
# Base URL of the deployed FastAPI backend (no trailing slash). This is the
# fix for the "Could not reach the analysis server at http://127.0.0.1:8000"
# error: if this is unset, the app falls back to localhost, which only works
# when you also run the backend on your own machine.
#   Local dev:  http://127.0.0.1:8000  (or 8001 if you start it on that port)
#   Production: https://resume-screening-api.onrender.com  (your Render URL)
VITE_RESUME_API_URL=https://resume-screening-api.onrender.com

# --- Supabase (already used by the portfolio) ---
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
