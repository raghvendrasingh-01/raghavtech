# Supabase (server-side, service-role key — never expose to the browser)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ---- LLM (OpenRouter or OpenAI) ----
# OpenRouter is OpenAI-compatible. Set this to enable real GPT planning.
OPENROUTER_API_KEY=
# Model id (OpenRouter "vendor/model" form). Examples:
#   openai/gpt-4o-mini   openai/gpt-4.1-mini   openai/gpt-5-mini
LLM_MODEL=openai/gpt-4o-mini
# (Alternatively, use OpenAI directly:)
# OPENAI_API_KEY=

# Comma-separated allowed origins for CORS (the Next.js app).
CORS_ORIGINS=http://localhost:3000
